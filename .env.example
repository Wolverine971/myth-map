# Mapbox public access token — required for map rendering, geocoding, and directions.
# Get one at https://account.mapbox.com/access-tokens/
PUBLIC_MAP_KEY=pk.your_mapbox_token_here

# Optional but recommended for weather.gov requests.
RADAR_USER_AGENT="Tiny Tribe Adventures radar (you@example.com)"

# Optional. Enables the Adventure Radar family events layer.
TICKETMASTER_API_KEY=
