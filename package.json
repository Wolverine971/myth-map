{
	"name": "myth-map",
	"version": "0.0.1",
	"packageManager": "pnpm@8.15.5",
	"engines": {
		"node": ">=18",
		"pnpm": ">=7.13"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"label-paths": "tsx labelFilePaths.ts",
		"build:locations": "tsx scripts/build-locations.ts",
		"content:sync": "tsx scripts/sync-location-content.ts",
		"content:status": "tsx scripts/content-status.ts",
		"gen:all": "pnpm format && pnpm content:sync && pnpm label-paths"
	},
	"devDependencies": {
		"@sveltejs/adapter-vercel": "^5.7.2",
		"@sveltejs/kit": "^2.0.0",
		"@sveltejs/vite-plugin-svelte": "^3.0.0",
		"@tailwindcss/forms": "^0.5.9",
		"@tailwindcss/typography": "^0.5.13",
		"@types/eslint": "^8.56.7",
		"@types/mapbox__mapbox-sdk": "^0.15.1",
		"@types/suncalc": "^1.9.2",
		"autoprefixer": "^10.4.19",
		"eslint": "^9.0.0",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-svelte": "^2.36.0",
		"flowbite": "^2.3.0",
		"flowbite-svelte": "^0.46.1",
		"flowbite-svelte-icons": "^1.6.1",
		"globals": "^15.0.0",
		"mdsvex": "^0.11.2",
		"postcss": "^8.4.38",
		"prettier": "^3.1.1",
		"prettier-plugin-svelte": "^3.1.2",
		"prettier-plugin-tailwindcss": "^0.5.14",
		"sass": "^1.77.6",
		"svelte": "^4.2.7",
		"svelte-check": "^3.6.0",
		"tailwindcss": "^3.4.4",
		"tslib": "^2.4.1",
		"tsx": "^4.19.4",
		"typescript": "^5.0.0",
		"typescript-eslint": "^8.0.0-alpha.20",
		"vite": "^5.0.3",
		"vite-plugin-tailwind-purgecss": "^0.3.3"
	},
	"type": "module",
	"dependencies": {
		"@fontsource-variable/bitter": "^5.2.10",
		"@fontsource-variable/inter": "^5.2.8",
		"@fontsource-variable/jetbrains-mono": "^5.2.8",
		"@mapbox/mapbox-sdk": "^0.16.0",
		"@types/mapbox-gl": "^3.1.0",
		"date-picker-svelte": "^2.13.0",
		"lucide-svelte": "^0.436.0",
		"mapbox-gl": "^3.4.0",
		"marked": "^13.0.2",
		"qrcode": "^1.5.4",
		"rehype-slug": "^6.0.0",
		"remark-abbr": "^1.4.2",
		"remark-github": "^12.0.0",
		"suncalc": "^1.9.0"
	}
}
